# The pilot defaults to development; override explicitly in other environments.
TUTORING_ENVIRONMENT=development
# Development may use the ignored default under backend/var. Test and production
# must supply an explicit database URL outside tracked and frontend-served paths.
# TUTORING_DATABASE_URL=sqlite:////absolute/path/to/tutoring.sqlite3
# Required outside development; generate a Fernet-compatible 256-bit key.
TUTORING_INVITATION_ENCRYPTION_KEY=
